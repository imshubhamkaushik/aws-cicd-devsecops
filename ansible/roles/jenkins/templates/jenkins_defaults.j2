# Jenkins startup configuration
# ANSIBLE MANAGED — do not edit manually

# JVM options
JAVA_OPTS="-Djenkins.install.runSetupWizard=false \
           -Dcasc.merge.strategy=override"

# JCasC — points Jenkins at its configuration-as-code file on startup
CASC_JENKINS_CONFIG=/var/lib/jenkins/casc_configs/jcasc.yaml

# Jenkins admin identity (read by JCasC securityRealm block)
JENKINS_ADMIN_USER="{{ jenkins_admin_user }}"
JENKINS_ADMIN_PASSWORD="{{ vault_jenkins_admin_password }}"

# Jenkins and SonarQube URLs
JENKINS_URL="{{ hostvars[groups['jenkins'][0]]['public_ip_address'] | default(hostvars[groups['jenkins'][0]].ansible_facts.public_ip_address)  }}"
SONARQUBE_HOST="{{ hostvars[groups['sonarqube'][0]]['private_ip_address'] | default(hostvars[groups['sonarqube'][0]].ansible_facts.private_ip_address) }}"

# Source control
GIT_REPO_URL="{{ git_repo_url }}"
GITHUB_TOKEN="{{ vault_github_token }}"

# SonarQube token
SONARQUBE_TOKEN="{{ vault_sonar_token }}"