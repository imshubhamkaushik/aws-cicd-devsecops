# SHARED VAULT — loaded for ALL hosts.
# Copy to vault.yaml and encrypt:
#   cp vault.yaml.example vault.yaml
#   ansible-vault encrypt group_vars/all/vault.yaml
#
# Edit later with:
#   ansible-vault edit group_vars/all/vault.yaml

# Jenkins
vault_jenkins_admin_password: "adminadmin"
vault_github_token:           ""

# SonarQube
vault_sonar_admin_password:   "adminadmin"

# Populated automatically by the sonarqube role on first run — leave blank initially
vault_sonar_token:            ""