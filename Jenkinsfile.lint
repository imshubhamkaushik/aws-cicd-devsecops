// =============================================================================
// DRAFT — NOT ACTIVE. This file is not referenced by jcasc.yaml's jobs: block,
// so no Jenkins job runs it and nothing triggers it. It exists so the stages
// are ready to go when you decide to turn this on — at that point:
//   1. Add a pipelineJob('lint') entry to jcasc.yaml (model it on the
//      existing 'app-cicd' job — same githubPush() trigger pattern).
//   2. Decide whether to move 'Secrets Scanning' out of Jenkinsfile.app-cicd
//      into here instead, or leave it duplicated in both. Moving it is more
//      correct (it's a full-repo scan either way, so running it twice is
//      redundant work, not extra protection) but duplicating it costs
//      nothing except a slightly slower app-cicd run, and means secret
//      scanning doesn't depend on this file actually being wired up
//      correctly on day one. Your call once this is real.
//   3. Run terraform fmt -check and helm lint by hand once, locally, before
//      trusting them as gates — see the comment on those two stages below
//      for why those two specifically haven't been verified the way the
//      others have.
// =============================================================================

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds(abortPrevious: true)
        timeout(time: 10, unit: 'MINUTES')
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        // ── Terraform ────────────────────────────────────────────────────────
        //
        // fmt -check is safe repo-wide — pure formatting, independent of
        // provider configuration. NOT verified locally (no network access to
        // the real terraform binary in the sandbox this was written in) —
        // run it once by hand before trusting it as a hard gate.
        //
        // validate only runs against the three real root configs, not module
        // directories (most don't declare their own required_providers, so
        // validating one directly always fails on a missing-provider error
        // regardless of whether the module's own code is correct) and not
        // platform-infra/env/staging (known, deliberately-unfixed validate
        // errors — see the full review. Validating it would make this stage
        // permanently red for a reason everyone already knows, which trains
        // people to ignore red builds. Revisit once staging reaches parity
        // with dev).
        stage('Terraform Format Check') {
            steps {
                sh '''
                set -e
                terraform fmt -check -recursive -diff terraform/
                '''
            }
        }

        stage('Terraform Validate') {
            steps {
                sh '''
                set -e
                for dir in \\
                    terraform/backend-bootstrap \\
                    terraform/bootstrap-infra \\
                    terraform/platform-infra/env/dev
                do
                    echo "=== terraform validate: ${dir} ==="
                    terraform -chdir="${dir}" init -backend=false -input=false >/dev/null
                    terraform -chdir="${dir}" validate
                done
                '''
            }
        }

        // ── Ansible ──────────────────────────────────────────────────────────
        //
        // .ansible-lint-ignore is a real baseline, generated by actually
        // running `ansible-lint --generate-ignore` against this repo's
        // playbook.yaml (180 pre-existing findings, almost entirely style:
        // missing FQCNs, CRLF trailing whitespace, an internal var-naming
        // convention). Confirmed this stage exits 0 with the ignore file in
        // place — it only fails on NEW violations, not the backlog.
        stage('Ansible Lint') {
            steps {
                sh '''
                set -e
                cd ansible
                ansible-lint playbook.yaml
                '''
            }
        }

        // ── Python ───────────────────────────────────────────────────────────
        //
        // ruff covers both jobs a separate flake8 + bandit pairing would —
        // confirmed by actually running `ruff check --select S` against
        // scripts/python/: it catches the identical subprocess-shell=True
        // findings bandit does (ruff's S602 = bandit's B602), so there's no
        // coverage gap from using one tool instead of two. Default ruleset
        // (style/correctness) plus S (security) both run here.
        stage('Python Lint') {
            steps {
                sh '''
                set -e
                cd scripts/python
                ruff check --select E,F,W,S .
                '''
            }
        }

        // ── Helm ─────────────────────────────────────────────────────────────
        //
        // NOT verified locally — same reason as Terraform fmt above (no
        // network access to the real helm binary in the sandbox this was
        // written in). Run it once by hand before trusting it as a gate.
        stage('Helm Lint') {
            steps {
                sh '''
                set -e
                helm lint helm/catalogix-hc --values helm/catalogix-hc/values-dev.yaml
                helm lint helm/catalogix-hc --values helm/catalogix-hc/values-staging.yaml
                helm lint helm/monitoring
                '''
            }
        }

        // ── Shell scripts ────────────────────────────────────────────────────
        stage('Shellcheck') {
            steps {
                sh '''
                set -e
                shellcheck create-key-pair.sh
                shellcheck scripts/install/*.sh
                '''
            }
        }

        // ── Secrets ──────────────────────────────────────────────────────────
        //
        // Full-repo scan. Currently duplicated with app-cicd's own
        // 'Secrets Scanning' stage — see the header comment at the top of
        // this file for the tradeoff on whether to de-duplicate once this
        // is actually wired up.
        stage('Secrets Scanning') {
            steps {
                sh '''
                set -e
                docker run --rm \\
                    -v $(pwd):/repo \\
                    zricethezav/gitleaks:v8.21.2 detect \\
                    --source /repo \\
                    --exit-code 1 \\
                    --redact
                '''
            }
        }
    }

    post {
        success {
            echo "Lint pipeline passed — terraform fmt/validate, ansible-lint, ruff, helm lint, shellcheck, gitleaks all clean."
        }
        failure {
            echo "Lint pipeline failed — check which stage above for the specific tool and finding."
        }
    }
}
